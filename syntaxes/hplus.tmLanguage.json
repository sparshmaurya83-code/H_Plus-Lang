{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "H+",
  "scopeName": "source.hplus",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#packageCalls"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.hplus",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.hplus",
          "match": "\\b(say|when|otherwise|use|let)\\b"
        }
      ]
    },
    "packageCalls": {
      "patterns": [
        {
          "name": "meta.function-call.hplus",
          "match": "\\b([a-zA-Z_][\\w]*)\\.([a-zA-Z_][\\w]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.namespace.hplus"
            },
            "2": {
              "name": "entity.name.function.hplus"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.hplus",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.hplus",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.hplus",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.hplus",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hplus",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.hplus",
          "match": "="
        },
        {
          "name": "punctuation.section.block.begin.hplus",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.hplus",
          "match": "\\}"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.hplus",
          "match": "\\b[a-zA-Z_][\\w]*\\b"
        }
      ]
    }
  }
}
