{
  "name": "hplus-language-support",
  "displayName": "H+ Language Support",
  "description": "Syntax highlighting for H+ (Hyper+) — say, when, use",
  "version": "0.0.1",
  "publisher": "sparshmaurya83",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "keywords": ["hplus", "hyper+", "syntax", "highlighting"],
  "contributes": {
    "languages": [
      {
        "id": "hplus",
        "aliases": ["H+", "Hyper+"],
        "extensions": [".h+"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hplus",
        "scopeName": "source.hplus",
        "path": "./syntaxes/hplus.tmLanguage.json"
      }
    ]
  }
}